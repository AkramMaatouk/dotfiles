# ─────────────────────────────────────────────
# Shell aliases
# ─────────────────────────────────────────────
alias zshconfig="code ~/.zshrc"
alias ohmyzsh="code ~/.oh-my-zsh ~/.zshrc"
alias zshrc="source ~/.zshrc"
alias bro="sudo"
alias shortcutconfig="code ~/.local/share/applications /usr/share/applications"
alias workspace="cd ~/myWorkspace"
